# Frontend Environment Variables
# Copy this file to .env.local for local development
# For production (Vercel), set these in the Vercel dashboard under Settings > Environment Variables

# Backend API URL - Railway backend
NEXT_PUBLIC_API_URL=https://readpoint-backend-production.up.railway.app/api

# Google OAuth Client ID (from Google Cloud Console)
# GANTI dengan Client ID yang baru dari Google Cloud Console!
NEXT_PUBLIC_GOOGLE_CLIENT_ID=GANTI_DENGAN_CLIENT_ID_ANDA.apps.googleusercontent.com
