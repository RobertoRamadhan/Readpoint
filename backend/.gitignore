# Laravel - Files yang TIDAK boleh push ke GitHub
*.log
.DS_Store
Thumbs.db

# Environment files - BERISI PASSWORD & SECRET
.env
.env.*
!.env.example

# IDE configs
.phpactor.json
/.fleet
/.idea
/.nova
/.vscode
/.zed

# Dependencies
/node_modules
/vendor

# Build artifacts
/public/build
/public/hot
/public/storage

# Laravel specific
/storage/*.key
/storage/pail
/.phpunit.cache
.phpunit.result.cache

# Keep storage structure but ignore contents
storage/app/public/*
!storage/app/public/.gitkeep
storage/app/private/*
!storage/app/private/.gitkeep
storage/framework/cache/data/*
!storage/framework/cache/data/.gitkeep
storage/framework/sessions/*
!storage/framework/sessions/.gitkeep
storage/framework/views/*
!storage/framework/views/.gitkeep
storage/logs/*
!storage/logs/.gitkeep

# cPanel specific
.cpanel.yml

# Auth & credentials
/auth.json
Homestead.json
Homestead.yaml
