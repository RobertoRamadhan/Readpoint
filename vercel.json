{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "installCommand": "(cd frontend || cd ../frontend) && npm install",
  "buildCommand": "(cd frontend || cd ../frontend) && npm run build",
  "devCommand": "(cd frontend || cd ../frontend) && npm run dev"
}
